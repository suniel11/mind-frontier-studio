OPENAI_API_KEY=put_your_new_key_here
OPENAI_TEXT_MODEL=gpt-5-mini
CREATIVE_DIRECTOR_MODEL=gpt-5-mini
OPENAI_IMAGE_MODEL=gpt-image-1
# Scene images are generated concurrently (app/services/media.py); this
# caps requests to at most this many gpt-image-1 calls per rolling 60s
# window across all concurrent workers, so parallelism can't burst past
# the account's actual per-minute image rate limit. Raise this if your
# account's tier allows more than 5/min.
OPENAI_IMAGE_RATE_LIMIT_PER_MINUTE=5
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=onyx
OPENAI_TIMEOUT_SECONDS=120
PORT=8000
YOUTUBE_CLIENT_SECRETS=client_secret.json
YOUTUBE_TOKEN_PATH=.secrets/youtube-token.json

# --- Cost-aware text-model routing (app/model_router) ----------------------
# Never applies to image generation (OPENAI_IMAGE_MODEL) or TTS
# (OPENAI_TTS_MODEL) -- those are unaffected by this section.
#
# MODEL_PROFILE selects which stages may try a lower-cost model:
#   studio   - always use the baseline models above directly (OPENAI_TEXT_MODEL /
#              CREATIVE_DIRECTOR_MODEL). Identical to pre-routing behavior.
#   standard - (default) keep the baseline model for the Creative Director
#              brief, research, and the final script; try a smaller model
#              for Creative Director questions, storyboard, character bible,
#              SEO, and other structured/classification stages.
#   economy  - try the smaller model everywhere except the final script and
#              difficult research synthesis, which stay on baseline.
#
# Every lower-cost output is checked with deterministic validation
# (app/model_router/quality_checks.py) before it is used. If it fails, that
# stage is automatically rerun on the baseline model and the baseline output
# is used instead -- this never silently ships a worse result to save cost.
MODEL_PROFILE=standard

# Set to false to disable lower-cost experimentation entirely (every stage
# resolves straight to baseline_model, same as MODEL_PROFILE=studio) without
# changing MODEL_PROFILE itself.
MODEL_AUTO_FALLBACK=true

# When a stage's quality comparison is inconclusive (no deterministic check
# could judge the output), prefer the baseline model rather than accepting
# an unverified lower-cost result.
MODEL_REQUIRE_BASELINE_QUALITY=true

# After this many lower-cost quality/schema failures for one stage, that
# stage's circuit breaker trips and it uses baseline_model directly for the
# rest of the current project (see app/model_router/circuit_breaker.py).
MODEL_FALLBACK_FAILURE_THRESHOLD=3

# After this many total stage-level fallbacks occur within one project run,
# every remaining stage in that project is forced onto baseline models
# (see app/model_router/project_state.py).
MODEL_PROJECT_FALLBACK_THRESHOLD=5

# The smaller/cheaper model economy and standard profiles try first. Not
# verified against any account -- if unsupported, the router detects the
# provider error and falls back to baseline_model automatically. Override
# with a model id known to work on your account if needed.
MODEL_LOWER_COST_DEFAULT=gpt-5-nano

# Optional per-stage overrides. Leave blank to use the active profile's
# default for that stage. Any value here takes priority over the profile
# (including in Studio, per "unless explicitly overridden").
MODEL_CREATIVE_DIRECTOR_QUESTIONS=
MODEL_CREATIVE_DIRECTOR_BRIEF=
MODEL_RESEARCH=
MODEL_SCRIPT=
MODEL_STORYBOARD=
MODEL_CHARACTER=
MODEL_VISUAL_DIRECTOR=
MODEL_PROMPT_COMPILER=
MODEL_VISUAL_CONTINUITY_PLANNER=
MODEL_SEO=
MODEL_QUALITY_REVIEW=
MODEL_MEMORY=
MODEL_METADATA=
MODEL_VALIDATION=

# --- Visual Asset Economy v3 (app.visual_continuity) -----------------------
# One high-quality generated image can be shared across several adjacent
# storyboard scenes when they are genuinely the same visual moment (same
# location/era/object/process), each scene then given a different camera
# treatment (zoom, pan, drift, tilt...) so it still reads as a distinct shot.
# Reduces image-generation API calls and render time; the planner always
# runs on the baseline text model (never the cost-saving tier) because a bad
# grouping decision has real quality risk -- see MODEL_VISUAL_CONTINUITY_PLANNER
# above if you want to override that. Any failure (disabled, provider error,
# or a structurally unusable plan) degrades to today's one-image-per-scene
# behavior automatically -- this can never make a production worse.
VISUAL_ASSET_ECONOMY=true

# Hard cap: no single generated image may be reused across more than this
# many consecutive scenes, no matter how confident the planner is.
MAX_CONSECUTIVE_REUSE=3

# Whether scenes that resolve to an identical image_prompt actually reuse
# the same generated image (true) or each still get their own fresh
# generation call (false) -- a debug/escape-hatch switch independent of
# VISUAL_ASSET_ECONOMY.
IMAGE_CACHE_ENABLED=true

# Minimum confidence (0.0-1.0) the planner must have that a merge is truly
# the same visual moment. Below this, the proposed group is rejected and
# every scene in it gets its own image instead.
MIN_GROUPING_CONFIDENCE=0.75
